# API base URLs
VITE_API_BASE_URL=https://api.deadlock-api.com

# Cloudflare Turnstile site key for AI chat verification
VITE_TURNSTILE_SITE_KEY=0x4AAAAAABs5lyUV9iomsdK2

# AI Assistant API base URL
VITE_AI_ASSISTANT_API_URL=https://ai-assistant.deadlock-api.com

# Deadlock AI Coach API base URL (the ai-agent service that powers /chat).
# Production default is https://ai.deadlock-api.com; set this to your local
# agent during development. Falls back to VITE_AI_ASSISTANT_API_URL, then
# https://ai.deadlock-api.com.
VITE_COACH_API_URL=http://localhost:8000

# PostHog analytics (optional — analytics disabled if token is missing)
VITE_PUBLIC_POSTHOG_TOKEN=
