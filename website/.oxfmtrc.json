{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "sortImports": {},
  "sortTailwindcss": {
    "stylesheet": "src/styles/tailwind.css",
    "functions": ["clsx", "cn", "cva"]
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".output",
    ".tanstack",
    ".vinxi",
    ".wrangler",
    "src/routeTree.gen.ts",
    "src/components/ui"
  ]
}
