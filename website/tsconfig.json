{
  "include": ["env.d.ts", "**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "lib": ["DOM", "ES2024"],
    "types": ["@react-router/node", "vite/client"],
    "isolatedModules": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "resolveJsonModule": true,
    "target": "ES2024",
    "allowJs": true,
    "skipLibCheck": true,
    "noUncheckedSideEffectImports": false,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "~/*": ["./app/*"]
    },
    "noEmit": true,
    "rootDirs": [".", "./.react-router/types"]
  },
  "exclude": ["opensrc"]
}
