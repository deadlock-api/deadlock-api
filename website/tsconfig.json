{
  "include": ["env.d.ts", "**/*.ts", "**/*.tsx"],
  "compilerOptions": {
    "lib": ["DOM", "ES2025"],
    "types": ["@react-router/node", "vite/client"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2025",
    "allowJs": true,
    "skipLibCheck": true,
    "paths": {
      "~/*": ["./app/*"]
    },
    "noEmit": true,
    "rootDirs": [".", "./.react-router/types"]
  },
  "exclude": ["opensrc"]
}
