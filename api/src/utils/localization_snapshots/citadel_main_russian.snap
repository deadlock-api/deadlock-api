    [
      "guide_overview_main_header",
      "Добро пожаловать"
    ],
    [
      "guide_the_map_main_header",
      "Обзор"
    ],
    [
      "guide_upgrades_main_header",
      "Наращивание мощи"
    ],
    [
      "guide_basics_main_header",
      "Управление"
    ],
    [
      "guide_advanced_main_header",
      "Особые движения"
